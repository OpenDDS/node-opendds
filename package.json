{
  "name": "opendds",
  "version": "0.3.0",
  "description": "OpenDDS module for Node.js",
  "main": "lib/node-opendds.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "install": "node-gyp rebuild",
    "test": "cd test && perl run_test.pl cpp2node && perl run_test.pl node2cpp && perl run_test.pl node2node",
    "lint:js": "eslint .",
    "lint:cpp": "clang-format --dry-run --Werror src/*.cpp src/*.h"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenDDS/node-opendds.git"
  },
  "keywords": [
    "dds",
    "opendds",
    "addon"
  ],
  "contributors": [
    "Adam Mitz <mitza@objectcomputing.com> (https://github.com/mitza-oci)",
    "Fred Hornsey <hornseyf@objectcomputing.com> (https://github.com/iguessthislldo)",
    "Justin R. Wilson <wilsonj@objectcomputing.com> (https://github.com/jrw972)",
    "Timothy Simpson <simpsont@objectcomputing.com> (https://github.com/simpsont-oci)",
    "Son Dinh <dinhs@objectcomputing.com> (https://github.com/sonndinh)"
  ],
  "license": "BSD-3-Clause",
  "gypfile": true,
  "dependencies": {
    "nan": "^2.26.2"
  },
  "devDependencies": {
    "eslint": "^10.4.1"
  }
}
